{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"VITE,AI\" -c \"cyan,magenta\" \"npm run dev:vite\" \"npm run dev:ai\"",
    "dev:vite": "npx tsx scripts/system-info.ts && vite",
    "dev:ai": "powershell -NoProfile -ExecutionPolicy Bypass -File src/ai/scripts/start-ai-server.ps1 gemma",
    "dev:wr": "powershell -NoProfile -ExecutionPolicy Bypass -File src/ai/scripts/start-ai-server.ps1 wr",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:ai": "npx tsx scripts/debugger-llm.ts benchmark",
    "test:ai:historical": "npx tsx scripts/debugger-llm.ts historical",
    "test:ai:compare": "npx tsx scripts/debugger-llm.ts compare",
    "test:toolcall": "npx tsx scripts/debugger-llm.ts toolcall",
    "test:guardrails": "npx tsx scripts/test-ai-guardrails.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
