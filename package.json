{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"VITE,GPU_AI,CPU_AI\" -c \"cyan,magenta,yellow\" \"npm run dev:vite\" \"npm run dev:ai:gpu\" \"npm run dev:ai:cpu\"",
    "dev:vite": "npx tsx scripts/system-info.ts && vite",
    "dev:ai:gpu": "src\\ai\\server\\llama-server.exe --model src\\ai\\models\\LFM2.5-1.2B-Instruct-Q8_0.gguf --port 8000 --host 127.0.0.1 --n-gpu-layers 999 --ctx-size 32768 --parallel 2 -cb --temp 0.0 --cache-type-k q8_0 --cache-type-v q8_0 --chat-template chatml",
    "dev:ai:cpu": "src\\ai\\server\\llama-server.exe --model src\\ai\\models\\LFM2.5-1.2B-Instruct-Q8_0.gguf --port 8001 --host 127.0.0.1 --n-gpu-layers 0 -t 4 --ctx-size 16384 --parallel 1 -cb --temp 0.2 --cache-type-k q8_0 --cache-type-v q8_0 --chat-template chatml",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
